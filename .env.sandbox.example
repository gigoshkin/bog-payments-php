# Copy this file to .env.sandbox and fill in your sandbox credentials.
# The test suite loads it automatically — no sourcing needed.
#
# Run all sandbox tests (non-interactive):
#   ./vendor/bin/phpunit --testsuite sandbox
#
# Run interactive flow tests (requires a real terminal, not CI):
#   ./vendor/bin/phpunit --testsuite sandbox --filter Interactive --testdox

# Required — obtain from businessmanager.bog.ge (sandbox section)
BOG_SANDBOX_CLIENT_ID=your_client_id_here
BOG_SANDBOX_CLIENT_SECRET=your_client_secret_here
