{
    "name": "gigoshkin/bog-payments-php",
    "description": "Bank of Georgia Payments API client library for PHP 8.2+",
    "type": "library",
    "keywords": ["bog", "bank-of-georgia", "payments", "psr-18", "ecommerce", "ipay"],
    "homepage": "https://github.com/gigoshkin/bog-payments-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Giorgi Kiknadze",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0"
    },
    "require-dev": {
        "infection/infection": "^0.32.6",
        "nyholm/psr7": "^1.8",
        "php-http/curl-client": "^2.4",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Bog\\Payments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bog\\Payments\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "stable"
}
