{
    "name": "gigoshkin/bog-payments-php",
    "description": "Bank of Georgia Payments API client library for PHP 8.1+",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1|^2.0"
    },
    "require-dev": {
        "infection/infection": "^0.32.6",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Bog\\Payments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bog\\Payments\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "stable"
}
